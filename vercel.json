{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/tracking.js",
      "dest": "/public/tracking.js",
      "headers": { "Cache-Control": "public, max-age=60, s-maxage=60" }
    },
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
